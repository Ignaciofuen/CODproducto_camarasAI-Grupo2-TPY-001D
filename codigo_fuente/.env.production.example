# =============================================================================
# Camaras-IA · Variables para deployment en Oracle Cloud
# =============================================================================
# Renombrá este archivo a `.env` dentro del servidor Oracle (mismo directorio
# que docker-compose.yml) y completá los valores reales.
# NUNCA committees este archivo con valores reales — solo el `.example`.
# =============================================================================

# ----- Postgres (interno al docker-compose) -----
POSTGRES_DB=camaras_ia
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CAMBIAR_ESTO_POR_UNA_PASS_LARGA_Y_ALEATORIA

# ----- MinIO -----
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=CAMBIAR_ESTO_TAMBIEN_LARGO_ALEATORIO

# ----- JWT (auth del backend) -----
# Generala con:
#   openssl rand -base64 48
JWT_SECRET=CAMBIAR_POR_OUTPUT_DE_openssl_rand_base64_48
