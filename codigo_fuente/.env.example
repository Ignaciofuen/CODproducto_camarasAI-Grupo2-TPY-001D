# =============================================================================
# Cámaras-IA · Variables de entorno
# =============================================================================
# Copiá este archivo como ".env" (sin .example) y completá los valores reales.
# El archivo .env NO debe subirse a Git (agregalo al .gitignore).
# =============================================================================

# --- PostgreSQL ---
CAMARAS_DB_HOST=localhost
CAMARAS_DB_PORT=5432
CAMARAS_DB_NAME=camaras_ia
CAMARAS_DB_USER=postgres
CAMARAS_DB_PASSWORD=cambiar_este_password

# Apagar persistencia sin borrar credenciales (útil para desarrollo):
#   0 = no guarda nada en DB
#   1 = guarda todo (default)
CAMARAS_GUARDAR_EN_DB=1

# Pool de conexiones (dejá los defaults salvo que escales a muchas cámaras)
CAMARAS_DB_POOL_MIN=1
CAMARAS_DB_POOL_MAX=5

# --- Telegram (MVP, una sola cuenta) ---
# Estos también viven en la tabla configuracion_sistema, pero podés sobreescribir
# acá si querés evitar escribir el token en la DB.
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=123456789
